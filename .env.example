# ---------------------------------------------------------------------------
# tesla-fleet-mqtt configuration. Copy to .env and fill in.
# .env is gitignored — never commit real secrets.
# ---------------------------------------------------------------------------

# --- Tesla Fleet API application (developer.tesla.com) ---
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
# OAuth redirect URI registered on the app (any https URL under your domain;
# it only needs to be reachable enough to copy the ?code= out of the address bar)
TESLA_REDIRECT_URI=https://tesla.example.com/auth/callback

# --- Region endpoints ---
# NA/APAC: https://fleet-api.prd.na.vn.cloud.tesla.com
# EU/MEA:  https://fleet-api.prd.eu.vn.cloud.tesla.com
# CN:      https://fleet-api.prd.cn.vn.cloud.tesla.cn
FLEET_API_BASE=https://fleet-api.prd.eu.vn.cloud.tesla.com
TESLA_AUTH_URL=https://auth.tesla.com/oauth2/v3/token

# --- Domains ---
# Where the 3rd-party public key is served for partner registration
# (must be reachable over valid public HTTPS): https://${PARTNER_DOMAIN}/.well-known/appspecific/com.tesla.3p.public-key.pem
PARTNER_DOMAIN=tesla.example.com
# Hostname the vehicle streams telemetry to (mTLS). Point its DNS at your public IP.
TELEMETRY_HOST=telemetry.example.com
# Public port the car connects to for telemetry (this is what you port-forward and register with Tesla)
TELEMETRY_PORT=443
# Address:port the fleet-telemetry container publishes on the host.
# Standalone: 0.0.0.0 and 443. Behind a reverse proxy doing SNI passthrough: bind to 127.0.0.1 (see README).
TELEMETRY_BIND=0.0.0.0

# --- Vehicle ---
TESLA_VIN=
# Filled by scripts/get-token.sh after the one-time OAuth login
TESLA_REFRESH_TOKEN=

# --- MQTT broker ---
# Use the bundled mosquitto (default) or point at your own broker.
# MQTT_HOST/MQTT_PORT are what the services DIAL: the bundled mosquitto always listens on
# mosquitto:1883 inside the docker network, so only change these for an external broker.
MQTT_HOST=mosquitto
MQTT_PORT=1883
# Host port the bundled mosquitto is published on (change this one if 1883 is taken on the host)
#MQTT_HOST_PORT=1883
MQTT_USER=tesla
MQTT_PASSWORD=
# Topic root: state -> ${MQTT_TOPIC_BASE}/<VIN>/v/<field>, commands in -> ${MQTT_TOPIC_BASE}/cmd/<command>
MQTT_TOPIC_BASE=tesla

# --- Historian (optional, profile "history": streams telemetry to InfluxDB 2.x) ---
# Enable by adding "history" to COMPOSE_PROFILES.
INFLUX_URL=http://influxdb:8086
INFLUX_ORG=
INFLUX_BUCKET=tesla
INFLUX_TOKEN=
INFLUX_MEASUREMENT=vehicle

# Sessionizer -> MariaDB (drive/charge/park sessions; same "history" profile).
# Apply db/schema.sql once and create the user before enabling.
DB_HOST=mariadb
DB_PORT=3306
DB_USER=tesla
DB_PASSWORD=
DB_NAME=tesla

# --- Home Assistant MQTT discovery (tesla-ha-discovery, profile "ha") ---
# tlwriter publishes derived live state to <base>/<vin>/ha/* and the discovery service
# advertises the entities. Enable profiles "history,ha" (history runs tlwriter, which
# feeds the ha/* topics) and point HA's MQTT integration at the same broker.
HA_PUBLISH=1
HA_DISCOVERY_PREFIX=homeassistant
HA_DEVICE_NAME=Tesla
HA_DEVICE_MODEL=Tesla
HA_DEVICE_MANUFACTURER=Tesla
HA_DISCOVERY_INTERVAL=300
# Geofencing is HA-native: the device_tracker reports GPS and Home Assistant's own zones
# (Settings -> Areas & Zones) resolve home/work/etc. No geofence coords needed here.
# Reverse-geocode drive start/end into pos.address (shown on the Trip dashboard). Public OSM
# Nominatim by default, throttled to 1 req/s. TLW_GEOCODE=0 disables; NOMINATIM_URL points at
# your own instance.
TLW_GEOCODE=1
NOMINATIM_URL=https://nominatim.openstreetmap.org/reverse
# Optional single HOME geofence: positions within HOME_RADIUS metres of HOME_LAT/HOME_LNG are
# named HOME_LABEL on the Trip dashboard instead of a street address (like teslalogger's home
# geofence). Leave HOME_LAT/HOME_LNG unset for plain geocoding everywhere.
#HOME_LAT=51.488518
#HOME_LNG=11.976849
HOME_RADIUS=50
HOME_LABEL=Home
# Name charge stops after the charging operator (like teslalogger's charger geofences) instead of
# a street address. On charge start the spot is looked up against Open Charge Map (needs OCM_API_KEY,
# a free key from openchargemap.org) then OSM's amenity=charging_station; unknown spots keep their
# street address, home charging stays HOME_LABEL. TLW_CHARGER_NAMES=0 disables.
# Timezone tlwriter writes timestamps in. The teslalogger schema stores local wall-clock time, so
# this should match your zone (and the Grafana datasource session tz). Default Europe/Berlin.
TLW_TZ=Europe/Berlin
TLW_CHARGER_NAMES=1
CHARGER_RADIUS=75
OVERPASS_URL=https://overpass-api.de/api/interpreter
# free key from https://openchargemap.org/site/profile/applications (blank = OSM-only)
OCM_API_KEY=

# Compose profiles to enable, comma-separated. Leave empty for none.
# history = influx/sessionizer/tlwriter; ha = Home Assistant discovery; tools = helper scripts.
COMPOSE_PROFILES=

# --- Misc ---
# Leave unset for normal `docker compose` use (paths resolve relative to the compose file).
# For socket-managed tools (Dockhand, Portainer) whose internal stack path differs from the
# host path, set this to the ABSOLUTE HOST path of the stack directory, e.g.
#   STACK_DIR=/mnt/.../appdata/dockhand/stacks/<host>/<stackname>
# STACK_DIR=
# Local-only port the command proxy listens on (not exposed publicly)
PROXY_PORT=4443
# Host port for the public-key nginx (put behind your HTTPS reverse proxy, or skip if you host the key elsewhere)
PUBKEY_PORT=8088
# Run containers as this uid:gid (must own the generated key/cert files)
PUID=1000
PGID=1000
TZ=Etc/UTC

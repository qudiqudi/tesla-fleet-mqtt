# Secrets and generated material — NEVER commit these
.env
config/config.json

# Keys & certificates (generated by scripts/generate-keys.sh)
keys/
proxy/
certs/
pubkey/.well-known/appspecific/*.pem

# Mosquitto runtime
mosquitto/data/
mosquitto/log/
mosquitto/config/passwd

# misc
*.srl
*.csr
*.ext

# python
__pycache__/
*.pyc
